APP_NAME="Wallpaper Platform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.yourdomain.com
APP_FRONTEND_URL=https://yourdomain.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=wallpaper_platform
DB_USERNAME=wallpaper_user
DB_PASSWORD=your_strong_password_here

# Redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Queue
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Cloudflare R2 Storage
FILESYSTEM_DISK=r2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=wallpaper-platform
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxx.r2.dev
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# AWS (fallback / alternative)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Filament Admin
FILAMENT_PATH=admin
SUPER_ADMIN_EMAIL=superadmin@yourdomain.com
SUPER_ADMIN_PASSWORD=your_very_strong_password

# Security
BCRYPT_ROUNDS=12
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

# Sanctum
SANCTUM_STATEFUL_DOMAINS=yourdomain.com

# Rate Limiting
API_RATE_LIMIT=60
DOWNLOAD_RATE_LIMIT=10
LIKE_RATE_LIMIT=30

# Image Processing
MAX_UPLOAD_SIZE=20480
ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp"
WATERMARK_ENABLED=true
WATERMARK_DEFAULT_OPACITY=70
THUMBNAIL_WIDTH=400
THUMBNAIL_HEIGHT=250
WEBP_QUALITY=85

# Activity Log
ACTIVITY_LOG_ENABLED=true
ACTIVITY_LOG_RETAIN_DAYS=365
